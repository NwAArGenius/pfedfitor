# Database
DB_USER=pdffixer
DB_PASSWORD=change_me_strong_password
DB_NAME=pdffixer

# Backend
SECRET_KEY=change_me_secret_key_min_32_chars

# CORS — comma-separated origins allowed to call the API
# Example: https://yourdomain.com or http://VPS_IP:3003
CORS_ORIGINS=http://localhost:3003

# Frontend — public URL of the backend API (baked at build time)
# Must be reachable from the user's browser, not from inside Docker
# Example: http://VPS_IP:8000/api/v1 or https://api.yourdomain.com/api/v1
NEXT_PUBLIC_API_URL=http://VPS_IP:8000/api/v1
